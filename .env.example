# ============================================================
# HelpGhar Backend — Environment Configuration
# ============================================================

# Application
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/helpghar
# Production: mongodb+srv://user:pass@cluster.mongodb.net/helpghar

# JWT — CHANGE THIS IN PRODUCTION
JWT_SECRET=helpghar_super_secret_jwt_key_change_in_production_2024
JWT_EXPIRES_IN=7d

# Admin Registration Secret
ADMIN_SECRET_KEY=helpghar_admin_secret_2024

# Platform Commission Rate (percentage)
PLATFORM_COMMISSION_RATE=10

# File Upload
UPLOAD_DEST=./uploads
MAX_FILE_SIZE=5242880

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100
